<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>

<AnchorPane prefHeight="489.0" prefWidth="768.0"
            xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.navios.controller.TripulanteController">
    <children>

        <HBox alignment="CENTER_LEFT" spacing="10.0"
              AnchorPane.leftAnchor="24.0"
              AnchorPane.rightAnchor="24.0"
              AnchorPane.topAnchor="16.0">
            <children>
                <TextField fx:id="txtPesquisa"
                           promptText="Pesquisar tripulante..."
                           prefHeight="30.0"
                           prefWidth="240.0" />
                <Button fx:id="btnSearchTripulante"
                        text="Pesquisar"
                        prefHeight="30.0"
                        mnemonicParsing="false"
                        onAction="#handleSearchTripulante" />
                <Button fx:id="btnAdicionarTripulante"
                        text="Adicionar Tripulante"
                        prefHeight="30.0"
                        mnemonicParsing="false"
                        onAction="#handleAdicionarTripulante"
                        style="-fx-background-color: #2e4a6b; -fx-text-fill: white; -fx-background-radius: 4;" />
            </children>
        </HBox>

        <TableView fx:id="tabelaTripulantes"
                   AnchorPane.leftAnchor="24.0"
                   AnchorPane.rightAnchor="24.0"
                   AnchorPane.topAnchor="58.0"
                   AnchorPane.bottomAnchor="16.0">
            <columns>
                <TableColumn fx:id="colNome"                  text="Nome"               prefWidth="150.0" />
                <TableColumn fx:id="colSobrenome"             text="Sobrenome"          prefWidth="150.0" />
                <TableColumn fx:id="colEstadoDisponibilidade" text="Estado"             prefWidth="120.0" />
                <TableColumn fx:id="colNacionalidade"         text="Nacionalidade"      prefWidth="130.0" />
                <TableColumn fx:id="colDataNascimento"        text="Data de Nascimento" prefWidth="150.0" />
                <TableColumn fx:id="colAcoes"                 text="Ações" />
            </columns>
        </TableView>

    </children>
</AnchorPane>