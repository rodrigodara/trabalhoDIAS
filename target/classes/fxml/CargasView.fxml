<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>

<AnchorPane prefHeight="489.0" prefWidth="768.0"
            xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.navios.controller.CargasController">
    <children>

        <HBox alignment="CENTER_LEFT" spacing="10.0"
              AnchorPane.leftAnchor="24.0"
              AnchorPane.rightAnchor="24.0"
              AnchorPane.topAnchor="16.0">
            <children>
                <TextField fx:id="txtPesquisa"
                           promptText="Pesquisar cargas..."
                           prefHeight="30.0"
                           prefWidth="240.0" />

                <Button fx:id="btnSearchCargas"
                        text="Pesquisar"
                        prefHeight="30.0"
                        mnemonicParsing="false"
                        onAction="#handleSearchCarga" />
                <Button fx:id="btnAdicionarCarga"
                        text="Adicionar Carga"
                        prefHeight="30.0"
                        mnemonicParsing="false"
                        onAction="#handleAdicionarCarga"
                        style="-fx-background-color: #2e4a6b; -fx-text-fill: white; -fx-background-radius: 4;" />
            </children>
        </HBox>

        <TableView fx:id="tabelaCargas"
                   AnchorPane.leftAnchor="24.0"
                   AnchorPane.rightAnchor="24.0"
                   AnchorPane.topAnchor="58.0"
                   AnchorPane.bottomAnchor="16.0">
            <columns>
                <TableColumn fx:id="colDesignacao"    text="Designação"       prefWidth="200.0" />
                <TableColumn fx:id="colTipo"          text="Tipo"             prefWidth="100.0" />
                <TableColumn fx:id="colVolume"        text="Volume (m³)"      prefWidth="120.0" />
                <TableColumn fx:id="colPeso"          text="Peso (kg)"        prefWidth="120.0" />
                <TableColumn fx:id="colPortoCarga"    text="Porto de Carga"   prefWidth="150.0" />
                <TableColumn fx:id="colPortoDescarga" text="Porto de Descarga" prefWidth="150.0" />
                <TableColumn fx:id="colAcoes" text="Ações"/>
            </columns>
        </TableView>

    </children>
</AnchorPane>