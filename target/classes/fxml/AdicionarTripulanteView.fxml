<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.DatePicker?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="420.0" prefWidth="400.0"
            xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.navios.controller.AdicionarTripulanteController">
    <children>
        <VBox spacing="12.0"
              AnchorPane.leftAnchor="24.0"
              AnchorPane.rightAnchor="24.0"
              AnchorPane.topAnchor="24.0"
              AnchorPane.bottomAnchor="24.0">

            <Label text="Nome" />
            <TextField fx:id="txtNome" promptText="Ex: João" />

            <Label text="Sobrenome" />
            <TextField fx:id="txtSobrenome" promptText="Ex: Silva" />

            <Label text="Estado de Disponibilidade" />
            <ComboBox fx:id="estadoCombo" prefWidth="Infinity" />

            <Label text="Nacionalidade" />
            <TextField fx:id="txtNacionalidade" promptText="Ex: Portuguesa" />

            <Label text="Data de Nascimento" />
            <DatePicker fx:id="dataNascimentoPicker" prefWidth="Infinity" />

            <Label fx:id="erroLabel" textFill="red" visible="false" managed="false" />

            <HBox spacing="10.0">
                <Button text="Cancelar"
                        prefWidth="170.0"
                        mnemonicParsing="false"
                        onAction="#handleFecharModal" />
                <Button text="Guardar"
                        prefWidth="170.0"
                        mnemonicParsing="false"
                        onAction="#handleGuardarTripulante"
                        style="-fx-background-color: #2e4a6b; -fx-text-fill: white; -fx-background-radius: 4;" />
            </HBox>

        </VBox>
    </children>
</AnchorPane>