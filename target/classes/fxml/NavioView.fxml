<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>

<AnchorPane prefHeight="489.0" prefWidth="768.0"
            xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.navios.controller.NavioController">
    <children>

        <HBox alignment="CENTER_LEFT" spacing="10.0"
              AnchorPane.leftAnchor="24.0"
              AnchorPane.rightAnchor="24.0"
              AnchorPane.topAnchor="16.0">
            <children>
                <TextField fx:id="txtSearchNavio"
                           promptText="Pesquisar navio..."
                           prefHeight="30.0"
                           prefWidth="240.0" />

                <Button fx:id="btnSearchNavio"
                        text="Pesquisar"
                        prefHeight="30.0"
                        mnemonicParsing="false"
                        onAction="#handleSearchNavio" />
                <Button fx:id="btnAdicionarNavio"
                        text="Adicionar Navio"
                        prefHeight="30.0"
                        mnemonicParsing="false"
                        onAction="#handleAdicionarNavio"
                        style="-fx-background-color: #2e4a6b; -fx-text-fill: white; -fx-background-radius: 4;" />
            </children>
        </HBox>

        <TableView fx:id="tabelaNavios"
                   AnchorPane.leftAnchor="24.0"
                   AnchorPane.rightAnchor="24.0"
                   AnchorPane.topAnchor="58.0"
                   AnchorPane.bottomAnchor="16.0">
            <columns>
                <TableColumn fx:id="colId"       text="ID" />
                <TableColumn fx:id="colNome"     text="Nome" />
                <TableColumn fx:id="colIMO"      text="IMO" />
                <TableColumn fx:id="colBandeira" text="Bandeira" />
                <TableColumn fx:id="colAno"      text="Ano Fabrico" />
                <TableColumn fx:id="colEstado"   text="Estado" />
                <TableColumn fx:id="colAcoes"    text="Ações" />
            </columns>
        </TableView>

    </children>
</AnchorPane>