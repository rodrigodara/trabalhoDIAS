<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>

<AnchorPane prefHeight="489.0" prefWidth="768.0"
            xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.navios.controller.ViagemController">
    <children>

        <HBox alignment="CENTER_LEFT" spacing="10.0"
              AnchorPane.leftAnchor="24.0"
              AnchorPane.rightAnchor="24.0"
              AnchorPane.topAnchor="16.0">
            <children>
                <TextField fx:id="txtPesquisa"
                           prefHeight="30.0" prefWidth="240.0"
                           promptText="Pesquisar viagem..."
                           onAction="#handleSearchViagem" />
                <Button fx:id="btnSearchViagem"
                        text="Pesquisar"
                        prefHeight="30.0"
                        mnemonicParsing="false"
                        onAction="#handleSearchViagem" />
                <Region HBox.hgrow="ALWAYS" />
                <Button fx:id="btnAdicionarViagem"
                        text="Adicionar Viagem" 
                        prefHeight="30.0"
                        mnemonicParsing="false"
                        onAction="#handleAdicionarViagem"
                        style="-fx-background-color: #2e4a6b; -fx-text-fill: white; -fx-background-radius: 4;" />
            </children>
        </HBox>

        <TableView fx:id="tabelaViagens"
                   AnchorPane.leftAnchor="24.0"
                   AnchorPane.rightAnchor="24.0"
                   AnchorPane.topAnchor="58.0"
                   AnchorPane.bottomAnchor="16.0">
            <columns>
                <TableColumn fx:id="colNomeViagem"  text="Nome da Viagem"   prefWidth="200.0" />
                <TableColumn fx:id="colOrigem"  text="Origem"   prefWidth="150.0" />
                <TableColumn fx:id="colDestino"     text="Destino"          prefWidth="150.0" />
                <TableColumn fx:id="colObservacoes" text="Observações"    prefWidth="220.0" />
            </columns>
        </TableView>

    </children>
</AnchorPane>