<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>

<AnchorPane prefHeight="489.0" prefWidth="768.0"
            xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.navios.controller.ViagemController"
            style="-fx-background-color: #FFFFFF;">
    <children>

        <HBox alignment="CENTER_LEFT" spacing="10.0"
              AnchorPane.leftAnchor="24.0"
              AnchorPane.rightAnchor="24.0"
              AnchorPane.topAnchor="20.0">
            <children>
                <TextField fx:id="txtPesquisa"
                           promptText="Pesquisar viagem..."
                           prefHeight="36.0"
                           prefWidth="260.0"
                           style="-fx-background-color: #F8F9FB; -fx-border-color: #D1D5DB; -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 0 14 0 14; -fx-font-size: 13px;" />

                <Button fx:id="btnSearchViagem"
                        text="Pesquisar"
                        prefHeight="36.0"
                        mnemonicParsing="false"
                        onAction="#handleSearchViagem"
                        style="-fx-background-color: #FFFFFF; -fx-border-color: #D1D5DB; -fx-border-radius: 8; -fx-background-radius: 8; -fx-text-fill: #374151; -fx-font-size: 13px; -fx-padding: 0 18 0 18; -fx-cursor: hand;" />

                <Region HBox.hgrow="ALWAYS" />

                <Button fx:id="btnAdicionarViagem"
                        text="＋ Adicionar Viagem"
                        prefHeight="36.0"
                        mnemonicParsing="false"
                        onAction="#handleAdicionarViagem"
                        style="-fx-background-color: #1E2433; -fx-text-fill: white; -fx-background-radius: 8; -fx-font-size: 13px; -fx-font-weight: bold; -fx-padding: 0 18 0 18; -fx-cursor: hand;" />
            </children>
        </HBox>

        <TableView fx:id="tabelaViagens"
                   style="-fx-background-color: #FFFFFF; -fx-border-color: #E8ECF2; -fx-border-radius: 8; -fx-background-radius: 8;"
                   AnchorPane.leftAnchor="24.0"
                   AnchorPane.rightAnchor="24.0"
                   AnchorPane.topAnchor="68.0"
                   AnchorPane.bottomAnchor="20.0">
            <columns>
                <TableColumn fx:id="colNavio"        text="Navio"              prefWidth="150.0" />
                <TableColumn fx:id="colDataPartida"  text="Data Partida"       prefWidth="100.0" />
                <TableColumn fx:id="colDataChegada"  text="Chegada Prevista"   prefWidth="120.0" />
                <TableColumn fx:id="colOrigem"       text="Porto de Origem"    prefWidth="130.0" />
                <TableColumn fx:id="colDestino"      text="Porto de Destino"   prefWidth="130.0" />
                <TableColumn fx:id="colEstado"       text="Estado"             prefWidth="100.0" />
                <TableColumn fx:id="colAcoes"        text="Ações" />
            </columns>
        </TableView>

    </children>
</AnchorPane>
