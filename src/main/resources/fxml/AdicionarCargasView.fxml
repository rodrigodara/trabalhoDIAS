<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<AnchorPane prefHeight="440.0" prefWidth="400.0"
            xmlns="http://javafx.com/javafx/17"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.navios.controller.AdicionarCargasController">
    <children>
        <VBox spacing="12.0"
              AnchorPane.leftAnchor="24.0"
              AnchorPane.rightAnchor="24.0"
              AnchorPane.topAnchor="24.0"
              AnchorPane.bottomAnchor="24.0">

            <Label text="Designação" />
            <TextField fx:id="txtDesignacao" promptText="Ex: Contentores de aço" />

            <Label text="Tipo de Carga" />
            <ComboBox fx:id="tipoCombo" prefWidth="Infinity" />

            <Label text="Volume (m³)" />
            <TextField fx:id="txtVolume" promptText="Ex: 12.5" />

            <Label text="Peso (kg)" />
            <TextField fx:id="txtPeso" promptText="Ex: 5000.0" />

            <Label text="Porto de Carga" />
            <ComboBox fx:id="portoCargaCombo" prefWidth="Infinity" />

            <Label text="Porto de Descarga" />
            <ComboBox fx:id="portoDescargaCombo" prefWidth="Infinity" />

            <Label fx:id="erroLabel" textFill="red" visible="false" managed="false" />

            <HBox spacing="10.0">
                <Button text="Cancelar"
                        prefWidth="170.0"
                        mnemonicParsing="false"
                        onAction="#handleFecharModal" />
                <Button text="Guardar"
                        prefWidth="170.0"
                        mnemonicParsing="false"
                        onAction="#handleGuardarCarga"
                        style="-fx-background-color: #2e4a6b; -fx-text-fill: white; -fx-background-radius: 4;" />
            </HBox>

        </VBox>
    </children>
</AnchorPane>