<?xml version="1.0" encoding="UTF-8"?>

<?import java.lang.String?>
<?import javafx.collections.FXCollections?>
<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.control.SpinnerValueFactory?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.Rectangle?>

<StackPane xmlns="http://javafx.com/javafx/17"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.navios.controller.AdicionarNavioController"
           style="-fx-background-color: rgba(0,0,0,0.45);">

    <VBox prefWidth="540" maxHeight="740" spacing="0"
          style="-fx-background-color: #FFFFFF; -fx-background-radius: 12; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.25), 24, 0, 0, 8);">

        <HBox alignment="CENTER_LEFT" spacing="12"
              style="-fx-background-color: #1E2433; -fx-background-radius: 12 12 0 0; -fx-padding: 18 20 18 24;">
            <Label text="Navio" style="-fx-text-fill: #6B8CFF; -fx-font-size: 14px; -fx-font-weight: bold;"/>
            <Label text="Adicionar Novo Navio" style="-fx-text-fill: #FFFFFF; -fx-font-size: 16px; -fx-font-weight: bold;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button text="X" onAction="#handleFecharModal"
                    style="-fx-background-color: transparent; -fx-text-fill: #8A93A8; -fx-font-size: 16px; -fx-cursor: hand; -fx-padding: 2 8 2 8; -fx-background-radius: 6;"/>
        </HBox>

        <Rectangle height="1" fill="#E8ECF2"/>

        <ScrollPane fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED"
                    style="-fx-background-color: transparent; -fx-background: transparent; -fx-border-color: transparent;"
                    VBox.vgrow="ALWAYS">
            <VBox spacing="18" style="-fx-background-color: #FFFFFF;">
                <padding>
                    <Insets top="24" right="24" bottom="8" left="24"/>
                </padding>

                <Label text="IDENTIFICACAO"
                       style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #9CA3AF; -fx-padding: 0 0 2 2;"/>

                <VBox spacing="6">
                    <Label text="Nome do Navio" style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #6B7280; -fx-padding: 0 0 0 2;"/>
                    <TextField fx:id="nomeNavioField" promptText="Ex: NP Lusitania"
                               style="-fx-background-color: #F8F9FB; -fx-border-color: #D1D5DB; -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 10 14 10 14; -fx-font-size: 14px;"/>
                    <Label text="* Obrigatorio" style="-fx-font-size: 11px; -fx-text-fill: #9CA3AF;"/>
                </VBox>

                <VBox spacing="6">
                    <Label text="Identificador IMO" style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #6B7280; -fx-padding: 0 0 0 2;"/>
                    <TextField fx:id="identificadorImoField" promptText="Ex: IMO9234567"
                               style="-fx-background-color: #F8F9FB; -fx-border-color: #D1D5DB; -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 10 14 10 14; -fx-font-size: 14px;"/>
                    <Label text="* Obrigatorio - unico por navio" style="-fx-font-size: 11px; -fx-text-fill: #9CA3AF;"/>
                </VBox>

                <HBox spacing="16">
                    <VBox spacing="6" HBox.hgrow="ALWAYS">
                        <Label text="Bandeira" style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #6B7280; -fx-padding: 0 0 0 2;"/>
                        <TextField fx:id="bandeiraField" promptText="Ex: Portugal"
                                   style="-fx-background-color: #F8F9FB; -fx-border-color: #D1D5DB; -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 10 14 10 14; -fx-font-size: 14px;"/>
                        <Label text="* Obrigatorio" style="-fx-font-size: 11px; -fx-text-fill: #9CA3AF;"/>
                    </VBox>
                    <VBox spacing="6" HBox.hgrow="ALWAYS">
                        <Label text="Ano de Fabrico" style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #6B7280; -fx-padding: 0 0 0 2;"/>
                        <TextField fx:id="anoFabricoField" promptText="Ex: 2018"
                                   style="-fx-background-color: #F8F9FB; -fx-border-color: #D1D5DB; -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 10 14 10 14; -fx-font-size: 14px;"/>
                        <Label text="* 1900 - ano atual" style="-fx-font-size: 11px; -fx-text-fill: #9CA3AF;"/>
                    </VBox>
                </HBox>

                <Rectangle height="1" fill="#F3F4F6"/>

                <Label text="CLASSIFICACAO"
                       style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #9CA3AF; -fx-padding: 4 0 2 2;"/>

                <VBox spacing="6">
                    <Label text="Tipo de Navio" style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #6B7280; -fx-padding: 0 0 0 2;"/>
                    <ComboBox fx:id="tipoNavioCombo" promptText="Selecionar tipo..."
                              maxWidth="Infinity"
                              style="-fx-background-color: #F8F9FB; -fx-border-color: #D1D5DB; -fx-border-radius: 8; -fx-background-radius: 8; -fx-font-size: 14px;"/>
                    <Label text="* Obrigatorio" style="-fx-font-size: 11px; -fx-text-fill: #9CA3AF;"/>
                </VBox>

                <VBox spacing="6">
                    <Label text="Estado Operacional" style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #6B7280; -fx-padding: 0 0 0 2;"/>
                    <ComboBox fx:id="estadoOperacionalCombo" promptText="Selecionar estado..."
                              maxWidth="Infinity"
                              style="-fx-background-color: #F8F9FB; -fx-border-color: #D1D5DB; -fx-border-radius: 8; -fx-background-radius: 8; -fx-font-size: 14px;">
                        <items>
                            <FXCollections fx:factory="observableArrayList">
                                <String fx:value="ativo"/>
                                <String fx:value="em manutenção"/>
                                <String fx:value="inativo"/>
                            </FXCollections>
                        </items>
                    </ComboBox>
                    <Label text="* Obrigatorio - predefinicao: ativo" style="-fx-font-size: 11px; -fx-text-fill: #9CA3AF;"/>
                </VBox>

                <Rectangle height="1" fill="#F3F4F6"/>

                <Label text="CAPACIDADE"
                       style="-fx-font-size: 11px; -fx-font-weight: bold; -fx-text-fill: #9CA3AF; -fx-padding: 4 0 2 2;"/>

                <HBox spacing="16">
                    <VBox spacing="6" HBox.hgrow="ALWAYS">
                        <Label text="N. Compartimentos" style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #6B7280; -fx-padding: 0 0 0 2;"/>
                        <Spinner fx:id="compartimentosSpinner" editable="true" maxWidth="Infinity"
                                 style="-fx-background-color: #F8F9FB; -fx-border-color: #D1D5DB; -fx-font-size: 14px;">
                            <valueFactory>
                                <SpinnerValueFactory.IntegerSpinnerValueFactory min="1" max="999" initialValue="1"/>
                            </valueFactory>
                        </Spinner>
                        <Label text="* Minimo: 1" style="-fx-font-size: 11px; -fx-text-fill: #9CA3AF;"/>
                    </VBox>
                    <VBox spacing="6" HBox.hgrow="ALWAYS">
                        <Label text="N. Maximo de Cargas" style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #6B7280; -fx-padding: 0 0 0 2;"/>
                        <Spinner fx:id="maxCargasSpinner" editable="true" maxWidth="Infinity"
                                 style="-fx-background-color: #F8F9FB; -fx-border-color: #D1D5DB; -fx-font-size: 14px;">
                            <valueFactory>
                                <SpinnerValueFactory.IntegerSpinnerValueFactory min="1" max="9999" initialValue="1"/>
                            </valueFactory>
                        </Spinner>
                        <Label text="* Nao pode exceder o maximo do Tipo" style="-fx-font-size: 11px; -fx-text-fill: #9CA3AF;"/>
                    </VBox>
                </HBox>
                <HBox spacing="16">
                    <VBox spacing="6" HBox.hgrow="ALWAYS">
                        <Label text="Capacidade de Carga (ton)"
                            style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #6B7280; -fx-padding: 0 0 0 2;"/>
                        <TextField fx:id="capacidadeCargaField" promptText="Ex: 50000"
                                style="-fx-background-color: #F8F9FB; -fx-border-color: #D1D5DB; -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 10 14 10 14; -fx-font-size: 14px;"/>
                        <Label text="* Peso maximo total das cargas em toneladas"
                            style="-fx-font-size: 11px; -fx-text-fill: #9CA3AF;"/>
                    </VBox>
                </HBox>

                <Label fx:id="erroLabel" text="" wrapText="true" visible="false" managed="false"
                       style="-fx-background-color: #FEF2F2; -fx-text-fill: #DC2626; -fx-font-size: 13px; -fx-padding: 10 14 10 14; -fx-background-radius: 8; -fx-border-color: #FECACA; -fx-border-radius: 8;"/>
            </VBox>
        </ScrollPane>

        <Rectangle height="1" fill="#E8ECF2"/>

        <HBox alignment="CENTER_RIGHT" spacing="12"
              style="-fx-background-color: #F8F9FB; -fx-background-radius: 0 0 12 12; -fx-padding: 16 24 20 24;">
            <Button text="Cancelar" onAction="#handleFecharModal"
                    style="-fx-background-color: #FFFFFF; -fx-border-color: #D1D5DB; -fx-border-radius: 8; -fx-background-radius: 8; -fx-text-fill: #374151; -fx-font-size: 14px; -fx-padding: 10 20 10 20; -fx-cursor: hand;"/>
            <Button text="Guardar Navio" defaultButton="true" onAction="#handleGuardarNavio"
                    style="-fx-background-color: #1E2433; -fx-background-radius: 8; -fx-text-fill: #FFFFFF; -fx-font-size: 14px; -fx-font-weight: bold; -fx-padding: 10 24 10 24; -fx-cursor: hand;"/>
        </HBox>

    </VBox>
</StackPane>
