<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.shape.Rectangle?>

<StackPane xmlns="http://javafx.com/javafx/17"
           xmlns:fx="http://javafx.com/fxml/1"
           fx:controller="com.navios.controller.AdicionarTripulanteController"
           style="-fx-background-color: rgba(0,0,0,0.45);">

    <VBox prefWidth="480" maxHeight="620" spacing="0"
          style="-fx-background-color: #FFFFFF; -fx-background-radius: 12; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.25), 24, 0, 0, 8);">

        <!-- Header -->
        <HBox alignment="CENTER_LEFT" spacing="12"
              style="-fx-background-color: #1E2433; -fx-background-radius: 12 12 0 0; -fx-padding: 18 20 18 24;">
            <Label text="👥" style="-fx-text-fill: #6B8CFF; -fx-font-size: 18px;"/>
            <Label text="Adicionar Novo Tripulante" style="-fx-text-fill: #FFFFFF; -fx-font-size: 16px; -fx-font-weight: bold;"/>
            <Region HBox.hgrow="ALWAYS"/>
            <Button text="✕" onAction="#handleFecharModal"
                    style="-fx-background-color: transparent; -fx-text-fill: #8A93A8; -fx-font-size: 16px; -fx-cursor: hand; -fx-padding: 2 8 2 8; -fx-background-radius: 6;"/>
        </HBox>

        <Rectangle height="1" fill="#E8ECF2"/>

        <!-- Body -->
        <ScrollPane fitToWidth="true" hbarPolicy="NEVER" vbarPolicy="AS_NEEDED"
                    style="-fx-background-color: transparent; -fx-background: transparent; -fx-border-color: transparent;"
                    VBox.vgrow="ALWAYS">
            <VBox spacing="16" style="-fx-background-color: #FFFFFF;">
                <padding>
                    <Insets top="24" right="24" bottom="8" left="24"/>
                </padding>

                <HBox spacing="16">
                    <VBox spacing="5" HBox.hgrow="ALWAYS">
                        <Label text="Nome *" style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #6B7280;"/>
                        <TextField fx:id="txtNome" promptText="Ex: João" maxWidth="Infinity"
                                   style="-fx-background-color: #F8F9FB; -fx-border-color: #D1D5DB; -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 10 14 10 14; -fx-font-size: 14px;"/>
                    </VBox>
                    <VBox spacing="5" HBox.hgrow="ALWAYS">
                        <Label text="Sobrenome *" style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #6B7280;"/>
                        <TextField fx:id="txtSobrenome" promptText="Ex: Silva" maxWidth="Infinity"
                                   style="-fx-background-color: #F8F9FB; -fx-border-color: #D1D5DB; -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 10 14 10 14; -fx-font-size: 14px;"/>
                    </VBox>
                </HBox>

                <VBox spacing="5">
                    <Label text="Estado de Disponibilidade *" style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #6B7280;"/>
                    <ComboBox fx:id="estadoCombo" promptText="Selecionar estado..." maxWidth="Infinity"
                              style="-fx-background-color: #F8F9FB; -fx-border-color: #D1D5DB; -fx-border-radius: 8; -fx-background-radius: 8; -fx-font-size: 14px;"/>
                </VBox>

                <HBox spacing="16">
                    <VBox spacing="5" HBox.hgrow="ALWAYS">
                        <Label text="Nacionalidade *" style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #6B7280;"/>
                        <TextField fx:id="txtNacionalidade" promptText="Ex: Portuguesa" maxWidth="Infinity"
                                   style="-fx-background-color: #F8F9FB; -fx-border-color: #D1D5DB; -fx-border-radius: 8; -fx-background-radius: 8; -fx-padding: 10 14 10 14; -fx-font-size: 14px;"/>
                    </VBox>
                    <VBox spacing="5" HBox.hgrow="ALWAYS">
                        <Label text="Data de Nascimento *" style="-fx-font-size: 12px; -fx-font-weight: bold; -fx-text-fill: #6B7280;"/>
                        <DatePicker fx:id="dataNascimentoPicker" maxWidth="Infinity"
                                    style="-fx-background-color: #F8F9FB; -fx-border-color: #D1D5DB; -fx-border-radius: 8; -fx-background-radius: 8; -fx-font-size: 14px;"/>
                    </VBox>
                </HBox>

                <Label fx:id="erroLabel" text="" wrapText="true" visible="false" managed="false"
                       style="-fx-background-color: #FEF2F2; -fx-text-fill: #DC2626; -fx-font-size: 13px; -fx-padding: 10 14 10 14; -fx-background-radius: 8; -fx-border-color: #FECACA; -fx-border-radius: 8;"/>
            </VBox>
        </ScrollPane>

        <Rectangle height="1" fill="#E8ECF2"/>

        <!-- Footer -->
        <HBox alignment="CENTER_RIGHT" spacing="12"
              style="-fx-background-color: #F8F9FB; -fx-background-radius: 0 0 12 12; -fx-padding: 16 24 20 24;">
            <Button text="Cancelar" onAction="#handleFecharModal"
                    style="-fx-background-color: #FFFFFF; -fx-border-color: #D1D5DB; -fx-border-radius: 8; -fx-background-radius: 8; -fx-text-fill: #374151; -fx-font-size: 14px; -fx-padding: 10 20 10 20; -fx-cursor: hand;"/>
            <Button text="  Guardar Tripulante  " defaultButton="true" onAction="#handleGuardarTripulante"
                    style="-fx-background-color: #1E2433; -fx-background-radius: 8; -fx-text-fill: #FFFFFF; -fx-font-size: 14px; -fx-font-weight: bold; -fx-padding: 10 24 10 24; -fx-cursor: hand;"/>
        </HBox>

    </VBox>

</StackPane>
