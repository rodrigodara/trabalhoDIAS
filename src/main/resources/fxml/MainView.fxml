<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Separator?>
<?import javafx.scene.layout.AnchorPane?>
<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.VBox?>

<BorderPane maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="600.0" prefWidth="900.0" xmlns="http://javafx.com/javafx/26" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.navios.controller.MainController">
   <left>
      <VBox fx:id="sidebar" prefHeight="600.0" prefWidth="160.0" spacing="0.0" style="-fx-background-color: #2c3e50;" BorderPane.alignment="CENTER">
         <children>
            <!-- Botão hamburger sempre visível -->
            <Button fx:id="btnMenu" mnemonicParsing="false" onAction="#handleToggleMenu" text="☰"
                    style="-fx-font-size: 20px; -fx-background-color: transparent; -fx-text-fill: white; -fx-cursor: hand; -fx-alignment: CENTER-LEFT;"
                    maxWidth="Infinity">
               <padding>
                  <Insets bottom="14.0" left="15.0" right="15.0" top="14.0" />
               </padding>
            </Button>

            <!-- Botões de navegação (colapsáveis) -->
            <VBox fx:id="navButtons" spacing="0.0">
               <children>
                  <Separator style="-fx-opacity: 0.3;" />

                  <Button fx:id="btnNavios" mnemonicParsing="false" onAction="#handleNavios" text="⚓  Navios"
                          style="-fx-background-color: transparent; -fx-text-fill: #ecf0f1; -fx-font-size: 13px; -fx-alignment: CENTER-LEFT; -fx-cursor: hand;"
                          maxWidth="Infinity">
                     <padding>
                        <Insets bottom="14.0" left="20.0" right="40.0" top="14.0" />
                     </padding>
                  </Button>

                  <Button fx:id="btnViagens" mnemonicParsing="false" onAction="#handleViagens" text="🚢  Viagens"
                          style="-fx-background-color: transparent; -fx-text-fill: #ecf0f1; -fx-font-size: 13px; -fx-alignment: CENTER-LEFT; -fx-cursor: hand;"
                          maxWidth="Infinity">
                     <padding>
                        <Insets bottom="14.0" left="20.0" right="40.0" top="14.0" />
                     </padding>
                  </Button>

                  <Button fx:id="btnCargas" mnemonicParsing="false" onAction="#handleCargas" text="📦  Cargas"
                          style="-fx-background-color: transparent; -fx-text-fill: #ecf0f1; -fx-font-size: 13px; -fx-alignment: CENTER-LEFT; -fx-cursor: hand;"
                          maxWidth="Infinity">
                     <padding>
                        <Insets bottom="14.0" left="20.0" right="40.0" top="14.0" />
                     </padding>
                  </Button>

                  <Button fx:id="btnTripulacao" mnemonicParsing="false" onAction="#handleTripulacao" text="👥  Tripulação"
                          style="-fx-background-color: transparent; -fx-text-fill: #ecf0f1; -fx-font-size: 13px; -fx-alignment: CENTER-LEFT; -fx-cursor: hand;"
                          maxWidth="Infinity">
                     <padding>
                        <Insets bottom="14.0" left="20.0" right="40.0" top="14.0" />
                     </padding>
                  </Button>
               </children>
            </VBox>
         </children>
      </VBox>
   </left>
   <center>
      <AnchorPane fx:id="mainContent" prefHeight="200.0" prefWidth="200.0" BorderPane.alignment="CENTER" />
   </center>
</BorderPane>
